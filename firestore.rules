rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      allow update: if request.auth != null && (
        request.auth.uid in resource.data.playerUids
        || isValidJoin()
      );

      allow delete: if request.auth != null
        && request.auth.uid in resource.data.playerUids;

      function isValidJoin() {
        let room = resource.data;
        let next = request.resource.data;
        return room.status == 'waiting'
          && room.players.size() < room.maxPlayers
          && !(request.auth.uid in room.playerUids)
          && request.auth.uid in next.playerUids
          && next.playerUids.size() == room.playerUids.size() + 1
          && next.players.size() == room.players.size() + 1
          && next.code == room.code
          && next.hostId == room.hostId
          && next.status == 'waiting';
      }
    }

    match /rankings/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /rivalries/{pairKey} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid in request.resource.data.playerUids;
    }
  }
}
